---
import AdminLayout from '../../layouts/AdminLayout.astro';
export const prerender = false;

const { DB } = Astro.locals.runtime.env;
const { results: entries } = await DB.prepare(
  'SELECT * FROM waitlist ORDER BY created_at DESC'
).all<{ id: number; email: string; source: string; created_at: string }>();

const sourceLabel: Record<string, string> = {
  hero:      'Homepage Hero',
  cta:       'CTA Section',
  investors: 'Investors Page',
  listings:  'Listings Page',
  unknown:   '—',
};
---
<AdminLayout title="Waitlist">
  <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:32px;flex-wrap:wrap;gap:16px;">
    <div>
      <h1 style="font-size:28px;margin-bottom:6px;">Waitlist</h1>
      <p style="color:var(--mid-grey);font-size:15px;">
        {entries.length} registered investor{entries.length !== 1 ? 's' : ''}
      </p>
    </div>
    <a
      href={`data:text/csv;charset=utf-8,${encodeURIComponent('id,email,source,created_at\n' + entries.map(e => `${e.id},${e.email},${e.source},${e.created_at}`).join('\n'))}`}
      download="waitlist.csv"
      class="btn-outline"
      style="font-size:13px;"
    >
      Export CSV ↓
    </a>
  </div>

  {entries.length === 0 ? (
    <div style="background:white;padding:56px;border-radius:8px;border:1px solid var(--light-grey);text-align:center;">
      <p style="color:var(--mid-grey);font-size:16px;">No signups yet.</p>
    </div>
  ) : (
    <div style="background:white;border-radius:8px;border:1px solid var(--light-grey);overflow:hidden;">
      <table style="width:100%;border-collapse:collapse;font-size:14px;">
        <thead>
          <tr style="border-bottom:1px solid var(--light-grey);background:var(--off-white);">
            <th style="text-align:left;padding:12px 20px;font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--mid-grey);">#</th>
            <th style="text-align:left;padding:12px 20px;font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--mid-grey);">Email</th>
            <th style="text-align:left;padding:12px 20px;font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--mid-grey);">Source</th>
            <th style="text-align:left;padding:12px 20px;font-size:11px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--mid-grey);">Date</th>
          </tr>
        </thead>
        <tbody>
          {entries.map((e, i) => (
            <tr style={`border-bottom:1px solid var(--light-grey);${i % 2 === 1 ? 'background:var(--off-white);' : ''}`}>
              <td style="padding:12px 20px;color:var(--mid-grey);">{e.id}</td>
              <td style="padding:12px 20px;">
                <a href={`mailto:${e.email}`} style="color:var(--charcoal);text-decoration:none;font-weight:500;">{e.email}</a>
              </td>
              <td style="padding:12px 20px;">
                <span style="font-size:12px;padding:2px 10px;border-radius:100px;background:rgba(61,122,90,0.1);color:var(--green);font-weight:500;">
                  {sourceLabel[e.source] ?? e.source}
                </span>
              </td>
              <td style="padding:12px 20px;color:var(--mid-grey);">{String(e.created_at).slice(0, 10)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>
