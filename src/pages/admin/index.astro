---
import AdminLayout from '../../layouts/AdminLayout.astro';
export const prerender = false;

const { DB } = Astro.locals.runtime.env;
const [projects, waitlist, submissions] = await Promise.all([
  DB.prepare('SELECT COUNT(*) as count FROM projects WHERE is_visible = 1').first<{ count: number }>(),
  DB.prepare('SELECT COUNT(*) as count FROM waitlist').first<{ count: number }>(),
  DB.prepare('SELECT COUNT(*) as count FROM project_submissions WHERE status = "new"').first<{ count: number }>(),
]);
---
<AdminLayout title="Dashboard">
  <h1 style="font-size:28px;margin-bottom:6px;">Dashboard</h1>
  <p style="color:var(--mid-grey);margin-bottom:40px;font-size:15px;">Power Yield admin overview</p>

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;margin-bottom:48px;">
    <div style="background:white;padding:28px 32px;border-radius:8px;border:1px solid var(--light-grey);">
      <p style="font-size:12px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--mid-grey);margin-bottom:12px;">Active Projects</p>
      <p style="font-size:44px;font-weight:700;color:var(--charcoal);line-height:1;">{projects?.count ?? 0}</p>
    </div>
    <div style="background:white;padding:28px 32px;border-radius:8px;border:1px solid var(--light-grey);">
      <p style="font-size:12px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--mid-grey);margin-bottom:12px;">Waitlist Signups</p>
      <p style="font-size:44px;font-weight:700;color:var(--charcoal);line-height:1;">{waitlist?.count ?? 0}</p>
    </div>
    <div style="background:white;padding:28px 32px;border-radius:8px;border:1px solid var(--light-grey);">
      <p style="font-size:12px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--mid-grey);margin-bottom:12px;">New Submissions</p>
      <p style="font-size:44px;font-weight:700;color:var(--charcoal);line-height:1;">{submissions?.count ?? 0}</p>
    </div>
  </div>

  <div style="display:flex;gap:12px;flex-wrap:wrap;">
    <a href="/admin/projects" class="btn-primary">Manage Projects</a>
    <a href="/admin/projects/new" class="btn-green">+ Add Project</a>
    <a href="/admin/waitlist" class="btn-outline">View Waitlist</a>
    <a href="/admin/submissions" class="btn-outline">View Submissions</a>
    <a href="/listings" class="btn-outline" target="_blank" rel="noopener">View Listings Page ↗</a>
  </div>
</AdminLayout>
