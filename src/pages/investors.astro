---
import Layout from '../layouts/Layout.astro';
export const prerender = true;
---
<Layout
  title="For Investors — Power Yield"
  description="Access institutional-grade renewable energy investments with full transparency, milestone reporting, and measurable ESG impact."
>

  <!-- ═══════════════════════════════════════════════════════
       HERO
  ════════════════════════════════════════════════════════════ -->
  <section class="hero hero--short">
    <div class="hero__pattern" aria-hidden="true">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid2" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse">
            <path d="M 80 0 L 0 0 0 80" fill="none" stroke="#1E1E1C" stroke-width="0.8"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid2)"/>
      </svg>
    </div>
    <div class="container">
      <div class="hero__inner">
        <p class="hero__eyebrow">For Investors</p>
        <h1>Your Capital, Working<br><em>for the Planet</em></h1>
        <p class="hero__sub">
          Access institutional-grade renewable energy investments with full transparency,
          milestone reporting, and measurable ESG impact.
        </p>
        <a href="#investors-waitlist" class="btn-green">Join the Waitlist &rarr;</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       WHY POWER YIELD
  ════════════════════════════════════════════════════════════ -->
  <section class="section">
    <div class="container">
      <span class="section-label">Why Power Yield</span>

      <div class="feature-grid">
        <!-- Feature 1 -->
        <div class="feature-card">
          <div class="feature-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="2" y="2" width="8" height="8" stroke="currentColor" stroke-width="1.5"/>
              <rect x="14" y="2" width="8" height="8" stroke="currentColor" stroke-width="1.5"/>
              <rect x="2" y="14" width="8" height="8" stroke="currentColor" stroke-width="1.5"/>
              <rect x="14" y="14" width="8" height="8" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h3>Fractional Access</h3>
          <p>Invest in projects normally reserved for family offices and institutions, starting with smaller ticket sizes. Power Yield removes the minimum investment barriers that have historically excluded private investors from infrastructure.</p>
        </div>

        <!-- Feature 2 -->
        <div class="feature-card">
          <div class="feature-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M12 2L2 7l10 5 10-5-10-5z" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linejoin="round"/>
              <path d="M2 17l10 5 10-5" stroke="currentColor" stroke-width="1.5" fill="none"/>
              <path d="M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" fill="none"/>
            </svg>
          </div>
          <h3>Threshold-Based Safety</h3>
          <p>Your capital is only deployed when a project reaches its full funding target. No partial deployments, no half-built projects. If a project does not reach threshold, your commitment is returned in full.</p>
        </div>

        <!-- Feature 3 -->
        <div class="feature-card">
          <div class="feature-card__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <polyline points="3,17 8,12 12,15 17,8 21,6" stroke="currentColor" stroke-width="1.5" stroke-linecap="square" fill="none"/>
              <line x1="3" y1="21" x2="21" y2="21" stroke="currentColor" stroke-width="1.5"/>
              <line x1="21" y1="6" x2="21" y2="21" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <h3>Milestone Transparency</h3>
          <p>Follow your investment through every phase with structured reporting on construction, commissioning, and operations. We apply the same reporting standards used by institutional infrastructure funds.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       INVESTMENT PROCESS
  ════════════════════════════════════════════════════════════ -->
  <section class="section section--off-white">
    <div class="container">
      <span class="section-label">Investment Process</span>

      <div class="split-grid">
        <div>
          <h2 style="margin-bottom:48px">From Registration<br>to Returns</h2>
          <nav class="timeline" aria-label="Investment process steps">
            <div class="timeline-step">
              <div class="timeline-step__line">
                <div class="timeline-step__dot">1</div>
                <div class="timeline-step__connector"></div>
              </div>
              <div class="timeline-step__body">
                <h4>Register &amp; verify your investor profile</h4>
                <p>Complete our onboarding process to confirm your investor status and preferences.</p>
              </div>
            </div>

            <div class="timeline-step">
              <div class="timeline-step__line">
                <div class="timeline-step__dot">2</div>
                <div class="timeline-step__connector"></div>
              </div>
              <div class="timeline-step__body">
                <h4>Browse available projects with full documentation</h4>
                <p>Access technical assessments, financial models, developer track records, and regulatory status for each project.</p>
              </div>
            </div>

            <div class="timeline-step">
              <div class="timeline-step__line">
                <div class="timeline-step__dot">3</div>
                <div class="timeline-step__connector"></div>
              </div>
              <div class="timeline-step__body">
                <h4>Submit a capital commitment</h4>
                <p>Reserve your fractional share for the project of your choice. Your commitment is held pending project activation.</p>
              </div>
            </div>

            <div class="timeline-step">
              <div class="timeline-step__line">
                <div class="timeline-step__dot">4</div>
                <div class="timeline-step__connector"></div>
              </div>
              <div class="timeline-step__body">
                <h4>Await project activation</h4>
                <p>Capital is only called once the project reaches its full funding threshold. You are notified at each stage.</p>
              </div>
            </div>

            <div class="timeline-step">
              <div class="timeline-step__line">
                <div class="timeline-step__dot">5</div>
                <div class="timeline-step__connector"></div>
              </div>
              <div class="timeline-step__body">
                <h4>Receive quarterly milestone reports</h4>
                <p>Stay informed through construction, commissioning, and operations with structured reporting on energy output and financial performance.</p>
              </div>
            </div>

            <div class="timeline-step">
              <div class="timeline-step__line">
                <div class="timeline-step__dot">6</div>
              </div>
              <div class="timeline-step__body">
                <h4>Earn structured returns over the project lifecycle</h4>
                <p>Receive distributions aligned with the project's cash flow profile, typically once operational.</p>
              </div>
            </div>
          </nav>
        </div>

        <!-- Right: at a glance card -->
        <div style="display:flex;align-items:center;justify-content:center;">
          <div style="width:100%;background:var(--charcoal);padding:48px 40px;display:flex;flex-direction:column;gap:12px;">
            <p style="color:var(--mid-grey);font-size:10px;letter-spacing:0.2em;text-transform:uppercase;font-weight:500;margin-bottom:12px;">At a Glance</p>
            <div style="display:flex;flex-direction:column;gap:20px;">
              <div style="border-bottom:1px solid rgba(255,255,255,0.1);padding-bottom:20px;">
                <p style="color:var(--mid-grey);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;font-weight:500;margin-bottom:6px;">Capital Deployment</p>
                <p style="color:var(--white);font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:300;">Only at full threshold</p>
              </div>
              <div style="border-bottom:1px solid rgba(255,255,255,0.1);padding-bottom:20px;">
                <p style="color:var(--mid-grey);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;font-weight:500;margin-bottom:6px;">Reporting frequency</p>
                <p style="color:var(--white);font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:300;">Quarterly milestones</p>
              </div>
              <div style="border-bottom:1px solid rgba(255,255,255,0.1);padding-bottom:20px;">
                <p style="color:var(--mid-grey);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;font-weight:500;margin-bottom:6px;">Target asset class</p>
                <p style="color:var(--white);font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:300;">Real Assets / Infrastructure</p>
              </div>
              <div>
                <p style="color:var(--mid-grey);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;font-weight:500;margin-bottom:6px;">ESG Classification</p>
                <p style="color:var(--green-light);font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:300;">Article 9 (SFDR) targeted</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       TARGET RETURNS & RISK PROFILE
  ════════════════════════════════════════════════════════════ -->
  <section class="section">
    <div class="container">
      <span class="section-label">Target Returns &amp; Risk Profile</span>

      <div class="split-grid">
        <!-- Left: key metrics dark card -->
        <div class="metrics-card">
          <div class="metrics-card__row">
            <span class="metrics-card__key">Target IRR</span>
            <span class="metrics-card__val">8–10% p.a.</span>
          </div>
          <div class="metrics-card__row">
            <span class="metrics-card__key">Investment horizon</span>
            <span class="metrics-card__val">8–15 years</span>
          </div>
          <div class="metrics-card__row">
            <span class="metrics-card__key">Asset class</span>
            <span class="metrics-card__val">Real Assets / Infrastructure</span>
          </div>
          <div class="metrics-card__row">
            <span class="metrics-card__key">Currency</span>
            <span class="metrics-card__val">EUR</span>
          </div>
          <div class="metrics-card__row">
            <span class="metrics-card__key">ESG classification</span>
            <span class="metrics-card__val" style="color:var(--green-light)">Article 9 (SFDR) targeted</span>
          </div>
        </div>

        <!-- Right: risk disclosure -->
        <div style="padding-top: 8px;">
          <h3 style="margin-bottom:24px;color:var(--charcoal)">Understanding the Risks</h3>
          <p style="margin-bottom:18px;">Infrastructure investments are illiquid and long-term in nature. Returns are projected based on energy yield models, PPA contracts, and market assumptions. All financial figures presented on this site are targets or estimates — not guarantees.</p>
          <p style="margin-bottom:18px;">Specific risks include construction delays, variability in energy production, changes in energy pricing, regulatory developments, and currency exposure. Each project will be accompanied by a full risk disclosure document.</p>
          <p style="font-size:13px;color:var(--mid-grey);border-top:1px solid var(--light-grey);padding-top:18px;margin-top:8px;line-height:1.7;"><strong style="color:var(--dark-grey);font-weight:500;">Capital at risk.</strong> Power Yield does not provide regulated investment advice. Please consult a qualified financial adviser before committing capital. Past performance of comparable assets is not indicative of future results.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       INVESTOR FAQ
  ════════════════════════════════════════════════════════════ -->
  <section class="section section--off-white">
    <div class="container">
      <span class="section-label">Investor FAQ</span>

      <div class="split-grid--wide split-grid">
        <div>
          <h2 style="margin-bottom:40px">Frequently Asked<br>Questions</h2>

          <div class="accordion" role="list">
            <div class="accordion-item" role="listitem">
              <button class="accordion-header" aria-expanded="false">
                What is the minimum investment amount?
                <span class="accordion-icon" aria-hidden="true"></span>
              </button>
              <div class="accordion-panel">
                <div class="accordion-panel__inner">
                  <p>Minimum ticket sizes will be confirmed at platform launch. Our goal is to make meaningful participation accessible to a broad range of investors, while maintaining the quality and structure of each offering.</p>
                </div>
              </div>
            </div>

            <div class="accordion-item" role="listitem">
              <button class="accordion-header" aria-expanded="false">
                How are projects selected?
                <span class="accordion-icon" aria-hidden="true"></span>
              </button>
              <div class="accordion-panel">
                <div class="accordion-panel__inner">
                  <p>Our team evaluates projects across multiple dimensions: technical due diligence, developer track record, regulatory and permitting status, revenue visibility (PPAs, feed-in tariffs), and projected yield based on independent energy assessments. Only projects that meet our full criteria are listed on the platform.</p>
                </div>
              </div>
            </div>

            <div class="accordion-item" role="listitem">
              <button class="accordion-header" aria-expanded="false">
                When do I receive returns?
                <span class="accordion-icon" aria-hidden="true"></span>
              </button>
              <div class="accordion-panel">
                <div class="accordion-panel__inner">
                  <p>Return structures vary by project. Most projects offer periodic distributions once operational, typically on a quarterly or semi-annual basis, with a final capital repayment at the end of the project lifecycle. Full return schedules are disclosed in each project's documentation.</p>
                </div>
              </div>
            </div>

            <div class="accordion-item" role="listitem">
              <button class="accordion-header" aria-expanded="false">
                Is my capital protected?
                <span class="accordion-icon" aria-hidden="true"></span>
              </button>
              <div class="accordion-panel">
                <div class="accordion-panel__inner">
                  <p>No. Renewable energy infrastructure investments carry risk including construction delays, energy price variability, and regulatory changes. Capital is not guaranteed. Full risk disclosures will accompany each project on the platform, and we encourage investors to review these carefully before committing.</p>
                </div>
              </div>
            </div>

            <div class="accordion-item" role="listitem">
              <button class="accordion-header" aria-expanded="false">
                How do I register?
                <span class="accordion-icon" aria-hidden="true"></span>
              </button>
              <div class="accordion-panel">
                <div class="accordion-panel__inner">
                  <p>Join the waitlist on our landing page using your email address. Early registrants will receive priority access to our first project launches, along with detailed platform documentation ahead of the public launch.</p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Decorative side stat -->
        <div style="display:flex;flex-direction:column;gap:32px;justify-content:center;">
          <div style="padding:40px;background:var(--green-pale);border-left:3px solid var(--green)">
            <p style="font-family:'Cormorant Garamond',serif;font-size:52px;font-weight:300;color:var(--charcoal);line-height:1;margin-bottom:12px;">1,200+</p>
            <p style="font-size:13px;color:var(--dark-grey)">Investors already registered on the waitlist.</p>
          </div>
          <div style="padding:40px;background:var(--charcoal)">
            <p style="font-family:'Cormorant Garamond',serif;font-size:52px;font-weight:300;color:var(--white);line-height:1;margin-bottom:12px;">12+</p>
            <p style="font-size:13px;color:var(--mid-grey)">Projects in active pipeline assessment.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       WAITLIST CTA
  ════════════════════════════════════════════════════════════ -->
  <section class="section section--green-pale waitlist-cta" id="investors-waitlist">
    <div class="container">
      <h2>Ready to Invest in the Energy Transition?</h2>
      <p>Join the waitlist to receive priority access to our first project launches.</p>

      <form class="waitlist-form" data-form="waitlist" data-success-msg="confirm" data-source="investors" novalidate>
        <div class="waitlist-form__row">
          <input type="email" placeholder="Your email address" aria-label="Email address" required/>
          <button type="submit" class="btn-green">Join the Waitlist &rarr;</button>
        </div>
        <div class="waitlist-form__success" role="alert" aria-live="polite">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="7.25" stroke="#3D7A5A" stroke-width="1.5"/>
            <path d="M4.5 8.5L7 11l4.5-5" stroke="#3D7A5A" stroke-width="1.5" stroke-linecap="square"/>
          </svg>
          Thank you — check your inbox for a confirmation.
        </div>
      </form>
    </div>
  </section>

</Layout>
