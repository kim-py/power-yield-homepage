---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Power Yield opens large-scale wind and solar infrastructure to private investors — with fractional participation, full transparency, and measurable climate impact.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{title}</title>
  <meta name="description" content={description}/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>

  <!-- ═══════════════════════════════════════════════════════
       NAVIGATION
  ════════════════════════════════════════════════════════════ -->
  <nav class="nav" role="navigation" aria-label="Main navigation">
    <div class="nav__inner">
      <a href="/" class="nav__brand" aria-label="Power Yield home">
        <svg width="44" height="44" viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="1" y="1" width="70" height="70" stroke="#1E1E1C" stroke-width="1.2"/>
          <line x1="1" y1="1" x2="30" y2="1" stroke="#3D7A5A" stroke-width="3"/>
          <path d="M16 20 L16 52 M16 20 L28 20 C34 20 37 24 37 29 C37 34 34 38 28 38 L16 38"
                stroke="#111110" stroke-width="2" stroke-linecap="square" fill="none"/>
          <path d="M42 20 L52 34 L62 20 M52 34 L52 52"
                stroke="#3D7A5A" stroke-width="2" stroke-linecap="square" fill="none"/>
        </svg>
        <div class="nav__wordmark">
          <span class="wordmark">Power Yield</span>
          <span class="tagline-sub">Green Energy Finance</span>
        </div>
      </a>

      <div class="nav__links">
        <a href="/investors" class="nav__link">For Investors</a>
        <a href="/listings" class="nav__link">Open Projects</a>
        <a href="/projects" class="nav__link">For Developers</a>
        <a href="/about" class="nav__link">About</a>
        <a href="/#waitlist-hero" class="btn-green">Join Waitlist</a>
      </div>

      <button class="nav__hamburger" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <!-- Mobile overlay -->
  <div class="nav__overlay" role="dialog" aria-modal="true" aria-label="Navigation menu">
    <button class="nav__overlay-close" aria-label="Close menu">&times;</button>
    <a href="/investors" class="nav__link">For Investors</a>
    <a href="/listings" class="nav__link">Open Projects</a>
    <a href="/projects" class="nav__link">For Developers</a>
    <a href="/about" class="nav__link">About</a>
    <a href="/#waitlist-hero" class="btn-green" style="margin-top:16px">Join Waitlist</a>
  </div>

  <main class="page-content">
    <slot />
  </main>

  <!-- ═══════════════════════════════════════════════════════
       FOOTER
  ════════════════════════════════════════════════════════════ -->
  <footer class="footer">
    <div class="container">
      <div class="footer__grid">
        <!-- Brand column -->
        <div class="footer__brand-col">
          <a href="/" class="nav__brand" style="margin-bottom:20px">
            <svg width="36" height="36" viewBox="0 0 72 72" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="1" y="1" width="70" height="70" stroke="#F8F7F4" stroke-width="1.2"/>
              <line x1="1" y1="1" x2="30" y2="1" stroke="#3D7A5A" stroke-width="3"/>
              <path d="M16 20 L16 52 M16 20 L28 20 C34 20 37 24 37 29 C37 34 34 38 28 38 L16 38"
                    stroke="#F8F7F4" stroke-width="2" stroke-linecap="square" fill="none"/>
              <path d="M42 20 L52 34 L62 20 M52 34 L52 52"
                    stroke="#3D7A5A" stroke-width="2" stroke-linecap="square" fill="none"/>
            </svg>
            <div class="nav__wordmark">
              <span class="wordmark">Power Yield</span>
              <span class="tagline-sub">Green Energy Finance</span>
            </div>
          </a>
          <p class="footer__tagline">
            Fractional investing in large-scale wind and solar infrastructure. Built for the energy transition.
          </p>
        </div>

        <!-- Nav column -->
        <div>
          <p class="footer__col-title">Navigate</p>
          <ul class="footer__links">
            <li><a href="/" class="footer__link">Home</a></li>
            <li><a href="/investors" class="footer__link">For Investors</a></li>
            <li><a href="/listings" class="footer__link">Open Projects</a></li>
            <li><a href="/projects" class="footer__link">For Developers</a></li>
            <li><a href="/about" class="footer__link">About Us</a></li>
          </ul>
        </div>

        <!-- Legal column -->
        <div>
          <p class="footer__col-title">Contact &amp; Legal</p>
          <ul class="footer__links">
            <li><a href="mailto:hi@power-yield.com" class="footer__contact-email">hi@power-yield.com</a></li>
            <li><span class="footer__link" style="cursor:default">Power Yield AG, Zürich</span></li>
          </ul>
        </div>
      </div>

      <div class="footer__bottom">
        <p class="footer__copyright">© 2025 Power Yield AG, Zürich &middot; All rights reserved &middot; Regulatory disclaimer</p>
        <p class="footer__disclaimer">
          Investing in renewable energy projects involves risk. Past performance is not indicative of future results.
          Power Yield does not provide investment advice. Capital at risk. Returns are projected and not guaranteed.
          Please consult a qualified financial adviser before making investment decisions.
        </p>
      </div>
    </div>
  </footer>

  <script src="/js/main.js" is:inline></script>
</body>
</html>
